this: a thought:Article ;
    dc:title "No Silver Bullet — Essence and Accident in Software Engineering" ;
    dc:creator "Frederick P. Brooks, Jr." ;
    dc:issued "1987-04"^^xsd:gYearMonth ;
    dc:publisher "IEEE" ;
    bibo:doi "10.1109/MC.1987.1663532" ;
