this: a thought:WebPage ;
    dc:title "On the spacetime positive energy theorem in arbitrary dimension" ;
    bibo:uri "https://arxiv.org/abs/2604.18561" ;
    dc:creator "[Submitted on 20 Apr 2026]" ;
    dc:publisher "arXiv.org" ;
    dc:abstract "We describe how the spacetime positive energy theorem in dimension $n \\geq 4$ follows from our recent work on the Riemannian version of the positive mass theorem. Our proof builds on the fundamental work of Schoen and Yau and the remarkable work of Eichmair, and uses the Jang equation with a capillary term. We also use the shielding principle from the work of Lesourd-Unger-Yau." ;
    dc:language "en" ;
    thought:accessedAt "2026-04-21T16:07:24.054Z"^^xsd:dateTime .
