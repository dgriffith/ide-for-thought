@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dc:      <http://purl.org/dc/terms/> .
@prefix minerva: <https://minerva.dev/ontology#> .
@prefix thought: <https://minerva.dev/ontology/thought#> .
@prefix prov:    <http://www.w3.org/ns/prov#> .

# ── Ontology ────────────────────────────────────────────────────────────────

thought: a owl:Ontology ;
    rdfs:label "Minerva Thought Ontology" ;
    rdfs:comment "An ontology for decomposing the epistemic structure of a thoughtbase. Extends Toulmin argumentation to cover explanation, inquiry, research, learning, planning, and other modes of thought." ;
    owl:versionInfo "0.1.0" ;
    owl:imports minerva: .

# ── Abstract Superclass ────────────────────────────────────────────────────

thought:Component a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Thought Component" ;
    rdfs:comment "Abstract superclass for all components of thought structure. A prov:Entity — something with provenance that can be attributed, generated, and traced." .

# ── Core Epistemic Components (extended Toulmin) ───────────────────────────

thought:Claim a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Claim" ;
    rdfs:comment "An assertion presented as true — the central node of an argument." .

thought:Grounds a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Grounds" ;
    rdfs:comment "Evidence, data, or facts offered in support of a claim." .

thought:Warrant a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Warrant" ;
    rdfs:comment "The reasoning principle that connects grounds to claim." .

thought:Backing a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Backing" ;
    rdfs:comment "Support for the warrant itself — why the reasoning principle holds." .

thought:Qualifier a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Qualifier" ;
    rdfs:comment "Conditions or degree of certainty limiting a claim." .

thought:Rebuttal a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Rebuttal" ;
    rdfs:comment "Conditions under which the claim does not hold." .

# ── Beyond Argumentation ───────────────────────────────────────────────────

thought:Question a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Question" ;
    rdfs:comment "An open inquiry — something the thoughtbase is trying to answer." .

thought:Hypothesis a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Hypothesis" ;
    rdfs:comment "A tentative claim offered for investigation, not yet established." .

thought:Definition a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Definition" ;
    rdfs:comment "A stipulative or descriptive definition of a term or concept." .

thought:Distinction a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Distinction" ;
    rdfs:comment "A differentiation between two concepts that might be confused." .

thought:Assumption a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Assumption" ;
    rdfs:comment "A premise taken as given, not argued for within the current scope." .

thought:Principle a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Principle" ;
    rdfs:comment "A general rule, heuristic, or law appealed to in reasoning." .

thought:Example a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Example" ;
    rdfs:comment "A concrete instance illustrating a more abstract component." .

thought:Analogy a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Analogy" ;
    rdfs:comment "A structural mapping between two domains." .

thought:Narrative a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Narrative" ;
    rdfs:comment "A causal or temporal sequence organizing events or ideas." .

thought:Goal a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Goal" ;
    rdfs:comment "A desired outcome motivating planning or action." .

thought:Plan a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Plan" ;
    rdfs:comment "A proposed sequence of actions toward a goal." .

thought:Observation a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Observation" ;
    rdfs:comment "A noted phenomenon or pattern, prior to interpretation." .

thought:Interpretation a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Interpretation" ;
    rdfs:comment "A reading or construal of an observation or text." .

thought:Tension a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Tension" ;
    rdfs:comment "An unresolved conflict between two components." .

thought:Synthesis a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Synthesis" ;
    rdfs:comment "An integration of multiple components into a unified position." .

thought:Implication a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Implication" ;
    rdfs:comment "A consequence that follows from one or more components." .

# ── Research & Evidence ────────────────────────────────────────────────────

thought:Source a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Source" ;
    rdfs:comment "A cited or referenced external authority or text." .

thought:Finding a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Finding" ;
    rdfs:comment "A reported result from research or investigation." .

thought:Methodology a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Methodology" ;
    rdfs:comment "An approach or procedure used to produce findings." .

thought:Gap a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Gap" ;
    rdfs:comment "An identified absence in knowledge or coverage." .

thought:Corroboration a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Corroboration" ;
    rdfs:comment "Independent evidence converging on the same conclusion." .

thought:Contradiction a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Contradiction" ;
    rdfs:comment "Evidence or reasoning that directly conflicts with another component." .

# ── Learning & Understanding ──────────────────────────────────────────────

thought:Concept a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Concept" ;
    rdfs:comment "A unit of understanding — a named idea to be grasped." .

thought:Prerequisite a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Prerequisite" ;
    rdfs:comment "A concept or skill required before another can be understood." .

thought:Misconception a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Misconception" ;
    rdfs:comment "A commonly held but incorrect understanding." .

thought:Insight a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Insight" ;
    rdfs:comment "A non-obvious understanding that shifts perspective." .

thought:Connection a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Connection" ;
    rdfs:comment "A recognized relationship between previously separate ideas." .

# ── Meta-Epistemic ────────────────────────────────────────────────────────

thought:Framework a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Framework" ;
    rdfs:comment "A conceptual lens or paradigm organizing analysis." .

thought:Criterion a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Criterion" ;
    rdfs:comment "A standard by which something is evaluated." .

thought:Scope a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Scope" ;
    rdfs:comment "A boundary condition defining what is and isn't under consideration." .

thought:Confidence a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Confidence" ;
    rdfs:comment "An epistemic status assessment of a component." .

thought:Status a owl:Class ;
    rdfs:subClassOf thought:Component ;
    rdfs:label "Status" ;
    rdfs:comment "Epistemic lifecycle state: proposed, explored, established, challenged, revised, abandoned." .

# ── Structural Relations ──────────────────────────────────────────────────

thought:supports a owl:ObjectProperty ;
    rdfs:label "supports" ;
    rdfs:comment "This component provides evidence or reasoning for another." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Component .

thought:challenges a owl:ObjectProperty ;
    rdfs:label "challenges" ;
    rdfs:comment "This component undermines or questions another." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Component .

thought:qualifies a owl:ObjectProperty ;
    rdfs:label "qualifies" ;
    rdfs:comment "This component limits or conditions another." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Component .

thought:refines a owl:ObjectProperty ;
    rdfs:label "refines" ;
    rdfs:comment "This component clarifies or sharpens another." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Component .

thought:presupposes a owl:ObjectProperty ;
    rdfs:label "presupposes" ;
    rdfs:comment "This component requires another to be accepted." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Component .

thought:exemplifies a owl:ObjectProperty ;
    rdfs:label "exemplifies" ;
    rdfs:comment "This component is a concrete instance of another." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Component .

thought:contrasts a owl:ObjectProperty ;
    rdfs:label "contrasts" ;
    rdfs:comment "This component is distinguished from another." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Component .

thought:synthesizes a owl:ObjectProperty ;
    rdfs:label "synthesizes" ;
    rdfs:comment "This component integrates multiple others." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Component .

thought:motivates a owl:ObjectProperty ;
    rdfs:label "motivates" ;
    rdfs:comment "This component provides rationale for another." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Component .

thought:addresses a owl:ObjectProperty ;
    rdfs:label "addresses" ;
    rdfs:comment "This component responds to a question." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Question .

thought:raises a owl:ObjectProperty ;
    rdfs:label "raises" ;
    rdfs:comment "This component generates a new question." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Question .

thought:resolves a owl:ObjectProperty ;
    rdfs:label "resolves" ;
    rdfs:comment "This component resolves a tension." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Tension .

thought:contradicts a owl:ObjectProperty ;
    rdfs:label "contradicts" ;
    rdfs:comment "This component directly conflicts with another." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Component .

thought:corroborates a owl:ObjectProperty ;
    rdfs:label "corroborates" ;
    rdfs:comment "This component independently confirms another." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Component .

thought:requires a owl:ObjectProperty ;
    rdfs:label "requires" ;
    rdfs:comment "Understanding this component requires another (learning prerequisite)." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Component .

thought:corrects a owl:ObjectProperty ;
    rdfs:label "corrects" ;
    rdfs:comment "This component addresses a misconception." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Misconception .

thought:cites a owl:ObjectProperty ;
    rdfs:label "cites" ;
    rdfs:comment "This component draws on an external source." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Source .

thought:identifies a owl:ObjectProperty ;
    rdfs:label "identifies" ;
    rdfs:comment "This component identifies a gap in knowledge." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Gap .

thought:connects a owl:ObjectProperty ;
    rdfs:label "connects" ;
    rdfs:comment "This component reveals a relationship between others." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Component .

# ── Grounding (linking back to source text) ───────────────────────────────

thought:groundedIn a owl:ObjectProperty ;
    rdfs:label "grounded in" ;
    rdfs:comment "The note containing the source text for this component." ;
    rdfs:domain thought:Component ;
    rdfs:range minerva:Note .

thought:sourceOffset a owl:DatatypeProperty ;
    rdfs:label "source offset" ;
    rdfs:comment "Character offset in the note where this component begins." ;
    rdfs:domain thought:Component ;
    rdfs:range xsd:integer .

thought:sourceLength a owl:DatatypeProperty ;
    rdfs:label "source length" ;
    rdfs:comment "Length of the source passage in characters." ;
    rdfs:domain thought:Component ;
    rdfs:range xsd:integer .

thought:sourceText a owl:DatatypeProperty ;
    rdfs:label "source text" ;
    rdfs:comment "The verbatim passage (for display without re-reading the file)." ;
    rdfs:domain thought:Component ;
    rdfs:range xsd:string .

# ── Metadata ──────────────────────────────────────────────────────────────

thought:label a owl:DatatypeProperty ;
    rdfs:label "label" ;
    rdfs:comment "Short human-readable summary of a thought component." ;
    rdfs:domain thought:Component ;
    rdfs:range xsd:string .

thought:extractedBy a owl:DatatypeProperty ;
    rdfs:subPropertyOf prov:wasAttributedTo ;
    rdfs:label "extracted by" ;
    rdfs:comment "Agent or method that identified this component." ;
    rdfs:domain thought:Component ;
    rdfs:range xsd:string .

thought:confidenceValue a owl:DatatypeProperty ;
    rdfs:label "confidence" ;
    rdfs:comment "0.0–1.0 confidence in the extraction." ;
    rdfs:domain thought:Component ;
    rdfs:range xsd:decimal .

thought:belongsTo a owl:ObjectProperty ;
    rdfs:label "belongs to" ;
    rdfs:comment "Framework under which this component is analyzed." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Framework .

thought:hasStatus a owl:ObjectProperty ;
    rdfs:label "has status" ;
    rdfs:comment "Epistemic lifecycle state of this component." ;
    rdfs:domain thought:Component ;
    rdfs:range thought:Status .

# ── Status Individuals ────────────────────────────────────────────────────

thought:proposed a thought:Status ;
    rdfs:label "Proposed" ;
    rdfs:comment "Newly introduced, not yet investigated." .

thought:explored a thought:Status ;
    rdfs:label "Explored" ;
    rdfs:comment "Under active investigation or development." .

thought:established a thought:Status ;
    rdfs:label "Established" ;
    rdfs:comment "Well-supported and accepted within the current scope." .

thought:challenged a thought:Status ;
    rdfs:label "Challenged" ;
    rdfs:comment "Faces significant counter-evidence or counter-argument." .

thought:revised a thought:Status ;
    rdfs:label "Revised" ;
    rdfs:comment "Modified in response to challenges or new evidence." .

thought:abandoned a thought:Status ;
    rdfs:label "Abandoned" ;
    rdfs:comment "No longer considered viable." .

# ════════════════════════════════════════════════════════════════════════════
# PROPOSALS — LLM-originated changes awaiting approval
# ════════════════════════════════════════════════════════════════════════════

thought:Proposal a owl:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Proposal" ;
    rdfs:comment "An LLM-proposed mutation to the knowledge graph, subject to human review. A prov:Entity generated by a Conversation activity." .

thought:ProposalStatus a owl:Class ;
    rdfs:label "Proposal Status" ;
    rdfs:comment "Lifecycle state of a proposal." .

# ── Proposal Status Individuals ───────────────────────────────────────────

thought:pending a thought:ProposalStatus ;
    rdfs:label "Pending" ;
    rdfs:comment "Awaiting human review." .

thought:approved a thought:ProposalStatus ;
    rdfs:label "Approved" ;
    rdfs:comment "Reviewed and accepted — mutation has been applied." .

thought:rejected a thought:ProposalStatus ;
    rdfs:label "Rejected" ;
    rdfs:comment "Reviewed and declined — mutation was not applied." .

thought:expired a thought:ProposalStatus ;
    rdfs:label "Expired" ;
    rdfs:comment "Auto-expired without review within the configured window." .

# ── Proposal Properties ───────────────────────────────────────────────────

thought:proposalStatus a owl:ObjectProperty ;
    rdfs:label "proposal status" ;
    rdfs:comment "Current lifecycle state of this proposal." ;
    rdfs:domain thought:Proposal ;
    rdfs:range thought:ProposalStatus .

thought:proposedBy a owl:DatatypeProperty ;
    rdfs:subPropertyOf prov:wasAttributedTo ;
    rdfs:label "proposed by" ;
    rdfs:comment "The agent or model that originated this proposal (e.g. 'llm:claude-sonnet-4')." ;
    rdfs:domain thought:Proposal ;
    rdfs:range xsd:string .

thought:proposedAt a owl:DatatypeProperty ;
    rdfs:subPropertyOf prov:generatedAtTime ;
    rdfs:label "proposed at" ;
    rdfs:comment "Timestamp when the proposal was created." ;
    rdfs:domain thought:Proposal ;
    rdfs:range xsd:dateTime .

thought:autoExpires a owl:DatatypeProperty ;
    rdfs:label "auto-expires" ;
    rdfs:comment "Timestamp after which the proposal auto-reverts to expired if not reviewed." ;
    rdfs:domain thought:Proposal ;
    rdfs:range xsd:dateTime .

thought:proposalDiff a owl:DatatypeProperty ;
    rdfs:label "proposal diff" ;
    rdfs:comment "Serialized representation of the proposed graph mutation (Turtle or JSON)." ;
    rdfs:domain thought:Proposal ;
    rdfs:range xsd:string .

thought:proposalNote a owl:DatatypeProperty ;
    rdfs:label "proposal note" ;
    rdfs:comment "Human-readable description of what this proposal does and why." ;
    rdfs:domain thought:Proposal ;
    rdfs:range xsd:string .

thought:operationType a owl:DatatypeProperty ;
    rdfs:label "operation type" ;
    rdfs:comment "The kind of graph mutation (e.g. 'new_claim', 'evidence_link', 'confidence_update', 'tag_addition', 'staleness_flag')." ;
    rdfs:domain thought:Proposal ;
    rdfs:range xsd:string .

thought:affectsNode a owl:ObjectProperty ;
    rdfs:label "affects node" ;
    rdfs:comment "The graph node that this proposal would modify or create." ;
    rdfs:domain thought:Proposal ;
    rdfs:range owl:Thing .

thought:conversationRef a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:wasGeneratedBy ;
    rdfs:label "conversation reference" ;
    rdfs:comment "The conversation that produced this proposal." ;
    rdfs:domain thought:Proposal ;
    rdfs:range thought:Conversation .

# ── Approval Policy ───────────────────────────────────────────────────────

thought:ApprovalPolicy a owl:Class ;
    rdfs:label "Approval Policy" ;
    rdfs:comment "Determines the approval tier for a given operation type: requires_approval, notify_only, or autonomous." .

thought:approvalTier a owl:DatatypeProperty ;
    rdfs:label "approval tier" ;
    rdfs:comment "The approval requirement: 'requires_approval', 'notify_only', or 'autonomous'." ;
    rdfs:domain thought:ApprovalPolicy ;
    rdfs:range xsd:string .

thought:forOperationType a owl:DatatypeProperty ;
    rdfs:label "for operation type" ;
    rdfs:comment "The operation type this policy applies to." ;
    rdfs:domain thought:ApprovalPolicy ;
    rdfs:range xsd:string .

# ════════════════════════════════════════════════════════════════════════════
# CONVERSATIONS — scoped interactions with LLM agents
# ════════════════════════════════════════════════════════════════════════════

thought:Conversation a owl:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:label "Conversation" ;
    rdfs:comment "A scoped, bounded interaction between the user and an LLM agent, initiated from a graph context. A prov:Activity that generates proposals and components." .

thought:ConversationStatus a owl:Class ;
    rdfs:label "Conversation Status" ;
    rdfs:comment "Lifecycle state of a conversation." .

# ── Conversation Status Individuals ───────────────────────────────────────

thought:active a thought:ConversationStatus ;
    rdfs:label "Active" ;
    rdfs:comment "Conversation is in progress." .

thought:resolved a thought:ConversationStatus ;
    rdfs:label "Resolved" ;
    rdfs:comment "Conversation completed with results filed to the graph." .

thought:abandonedConversation a thought:ConversationStatus ;
    rdfs:label "Abandoned" ;
    rdfs:comment "Conversation closed without filing results." .

# ── Conversation Properties ───────────────────────────────────────────────

thought:conversationStatus a owl:ObjectProperty ;
    rdfs:label "conversation status" ;
    rdfs:comment "Current lifecycle state of this conversation." ;
    rdfs:domain thought:Conversation ;
    rdfs:range thought:ConversationStatus .

thought:startedAt a owl:DatatypeProperty ;
    rdfs:subPropertyOf prov:startedAtTime ;
    rdfs:label "started at" ;
    rdfs:comment "Timestamp when the conversation began." ;
    rdfs:domain thought:Conversation ;
    rdfs:range xsd:dateTime .

thought:resolvedAt a owl:DatatypeProperty ;
    rdfs:subPropertyOf prov:endedAtTime ;
    rdfs:label "resolved at" ;
    rdfs:comment "Timestamp when the conversation was resolved." ;
    rdfs:domain thought:Conversation ;
    rdfs:range xsd:dateTime .

thought:trigger a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:used ;
    rdfs:label "trigger" ;
    rdfs:comment "The graph node or component that triggered this conversation." ;
    rdfs:domain thought:Conversation ;
    rdfs:range owl:Thing .

thought:contextNote a owl:ObjectProperty ;
    rdfs:label "context note" ;
    rdfs:comment "A note that was part of this conversation's context bundle." ;
    rdfs:domain thought:Conversation ;
    rdfs:range minerva:Note .

thought:conversationContent a owl:DatatypeProperty ;
    rdfs:label "conversation content" ;
    rdfs:comment "The full conversation transcript (JSON-serialized message array)." ;
    rdfs:domain thought:Conversation ;
    rdfs:range xsd:string .

thought:producedProposal a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:generated ;
    rdfs:label "produced proposal" ;
    rdfs:comment "A proposal that emerged from this conversation." ;
    rdfs:domain thought:Conversation ;
    rdfs:range thought:Proposal .

thought:producedComponent a owl:ObjectProperty ;
    rdfs:subPropertyOf prov:generated ;
    rdfs:label "produced component" ;
    rdfs:comment "A thought component that was crystallized from this conversation." ;
    rdfs:domain thought:Conversation ;
    rdfs:range thought:Component .

# ════════════════════════════════════════════════════════════════════════════
# EPISTEMIC DEFECTS — what goes wrong in thinking
# ════════════════════════════════════════════════════════════════════════════
#
# Real thoughtbases contain flawed reasoning, biased thinking, rhetorical
# moves that persuade without warranting, and structural gaps. Agents need
# vocabulary to diagnose what's broken, not just what's well-formed.

# ── Defect Superclass ─────────────────────────────────────────────────────

thought:Defect a owl:Class ;
    rdfs:label "Epistemic Defect" ;
    rdfs:comment "Abstract superclass for all identified problems in reasoning. Not itself a Component — defects describe problems WITH components." .

# ── Logical Fallacies ─────────────────────────────────────────────────────
# Categories of invalid reasoning. Instances name the specific fallacy.

thought:FormalFallacy a owl:Class ;
    rdfs:subClassOf thought:Defect ;
    rdfs:label "Formal Fallacy" ;
    rdfs:comment "An error in logical structure — the argument form is invalid regardless of content. E.g., affirming the consequent, denying the antecedent, undistributed middle." .

thought:InformalFallacy a owl:Class ;
    rdfs:subClassOf thought:Defect ;
    rdfs:label "Informal Fallacy" ;
    rdfs:comment "An error in reasoning that is not purely structural. Includes fallacies of relevance, presumption, and ambiguity." .

thought:FallacyOfRelevance a owl:Class ;
    rdfs:subClassOf thought:InformalFallacy ;
    rdfs:label "Fallacy of Relevance" ;
    rdfs:comment "Premises are logically irrelevant to the conclusion. E.g., ad hominem, appeal to emotion, appeal to authority, red herring, tu quoque, appeal to popularity." .

thought:FallacyOfPresumption a owl:Class ;
    rdfs:subClassOf thought:InformalFallacy ;
    rdfs:label "Fallacy of Presumption" ;
    rdfs:comment "The argument presumes what it needs to prove or smuggles in unwarranted assumptions. E.g., begging the question, false dilemma, loaded question, complex question, slippery slope." .

thought:FallacyOfAmbiguity a owl:Class ;
    rdfs:subClassOf thought:InformalFallacy ;
    rdfs:label "Fallacy of Ambiguity" ;
    rdfs:comment "The argument exploits unclear or shifting meaning. E.g., equivocation, amphiboly, accent, composition, division." .

thought:FallacyOfInduction a owl:Class ;
    rdfs:subClassOf thought:InformalFallacy ;
    rdfs:label "Fallacy of Induction" ;
    rdfs:comment "An error in generalizing from evidence. E.g., hasty generalization, cherry-picking, survivorship bias, base rate neglect, false cause, post hoc." .

# ── Cognitive Biases ──────────────────────────────────────────────────────
# Systematic patterns of deviation from rational judgment.

thought:CognitiveBias a owl:Class ;
    rdfs:subClassOf thought:Defect ;
    rdfs:label "Cognitive Bias" ;
    rdfs:comment "A systematic pattern of deviation from rational judgment. Not a logical error but a predictable tendency in how humans process information." .

thought:ConfirmationBias a owl:Class ;
    rdfs:subClassOf thought:CognitiveBias ;
    rdfs:label "Confirmation Bias" ;
    rdfs:comment "Favoring information that confirms existing beliefs while discounting disconfirming evidence." .

thought:AnchoringBias a owl:Class ;
    rdfs:subClassOf thought:CognitiveBias ;
    rdfs:label "Anchoring Bias" ;
    rdfs:comment "Over-relying on the first piece of information encountered when making judgments." .

thought:AvailabilityBias a owl:Class ;
    rdfs:subClassOf thought:CognitiveBias ;
    rdfs:label "Availability Bias" ;
    rdfs:comment "Overestimating the likelihood of events that come easily to mind." .

thought:FramingEffect a owl:Class ;
    rdfs:subClassOf thought:CognitiveBias ;
    rdfs:label "Framing Effect" ;
    rdfs:comment "Drawing different conclusions from the same information depending on how it is presented." .

thought:DunningKruger a owl:Class ;
    rdfs:subClassOf thought:CognitiveBias ;
    rdfs:label "Dunning-Kruger Effect" ;
    rdfs:comment "Overestimating one's competence in areas where one lacks expertise." .

thought:StatusQuoBias a owl:Class ;
    rdfs:subClassOf thought:CognitiveBias ;
    rdfs:label "Status Quo Bias" ;
    rdfs:comment "Preference for the current state of affairs regardless of merit." .

thought:SunkCostFallacy a owl:Class ;
    rdfs:subClassOf thought:CognitiveBias ;
    rdfs:label "Sunk Cost Fallacy" ;
    rdfs:comment "Continuing an endeavor because of previously invested resources rather than future value." .

thought:HindsightBias a owl:Class ;
    rdfs:subClassOf thought:CognitiveBias ;
    rdfs:label "Hindsight Bias" ;
    rdfs:comment "Believing after the fact that an outcome was predictable, distorting assessment of reasoning quality." .

# ── Rhetorical Moves ─────────────────────────────────────────────────────
# Persuasion techniques that substitute for warranted reasoning.

thought:RhetoricalMove a owl:Class ;
    rdfs:subClassOf thought:Defect ;
    rdfs:label "Rhetorical Move" ;
    rdfs:comment "A persuasion technique that substitutes social or emotional force for epistemic warrant." .

thought:Strawman a owl:Class ;
    rdfs:subClassOf thought:RhetoricalMove ;
    rdfs:label "Strawman" ;
    rdfs:comment "Misrepresenting an opposing position to make it easier to attack." .

thought:Motte_and_Bailey a owl:Class ;
    rdfs:subClassOf thought:RhetoricalMove ;
    rdfs:label "Motte-and-Bailey" ;
    rdfs:comment "Conflating a defensible claim (motte) with a more ambitious one (bailey), retreating to the motte when challenged." .

thought:Deepity a owl:Class ;
    rdfs:subClassOf thought:RhetoricalMove ;
    rdfs:label "Deepity" ;
    rdfs:comment "A statement that sounds profound but on one reading is trivially true and on another is false." .

thought:Whataboutism a owl:Class ;
    rdfs:subClassOf thought:RhetoricalMove ;
    rdfs:label "Whataboutism" ;
    rdfs:comment "Deflecting criticism by pointing to someone else's failings rather than addressing the point." .

thought:GishGallop a owl:Class ;
    rdfs:subClassOf thought:RhetoricalMove ;
    rdfs:label "Gish Gallop" ;
    rdfs:comment "Overwhelming with many weak arguments rather than building strong ones." .

thought:SeaLioning a owl:Class ;
    rdfs:subClassOf thought:RhetoricalMove ;
    rdfs:label "Sea-Lioning" ;
    rdfs:comment "Persistent, bad-faith requests for evidence or explanation disguised as genuine inquiry." .

# ── Structural Defects ────────────────────────────────────────────────────
# Problems with how an argument or analysis is constructed.

thought:StructuralDefect a owl:Class ;
    rdfs:subClassOf thought:Defect ;
    rdfs:label "Structural Defect" ;
    rdfs:comment "A problem with how reasoning is assembled, independent of content." .

thought:CircularReasoning a owl:Class ;
    rdfs:subClassOf thought:StructuralDefect ;
    rdfs:label "Circular Reasoning" ;
    rdfs:comment "The conclusion is assumed in the premises." .

thought:NonSequitur a owl:Class ;
    rdfs:subClassOf thought:StructuralDefect ;
    rdfs:label "Non Sequitur" ;
    rdfs:comment "The conclusion does not follow from the premises." .

thought:UnsupportedClaim a owl:Class ;
    rdfs:subClassOf thought:StructuralDefect ;
    rdfs:label "Unsupported Claim" ;
    rdfs:comment "A claim made without grounds, warrant, or evidence." .

thought:MissingWarrant a owl:Class ;
    rdfs:subClassOf thought:StructuralDefect ;
    rdfs:label "Missing Warrant" ;
    rdfs:comment "Grounds are offered for a claim but the reasoning connecting them is unstated." .

thought:OverGeneralization a owl:Class ;
    rdfs:subClassOf thought:StructuralDefect ;
    rdfs:label "Over-Generalization" ;
    rdfs:comment "A conclusion drawn more broadly than the evidence supports." .

thought:FalseEquivalence a owl:Class ;
    rdfs:subClassOf thought:StructuralDefect ;
    rdfs:label "False Equivalence" ;
    rdfs:comment "Treating significantly different things as if they were the same." .

thought:MovingGoalposts a owl:Class ;
    rdfs:subClassOf thought:StructuralDefect ;
    rdfs:label "Moving Goalposts" ;
    rdfs:comment "Changing the criteria for success after evidence is presented." .

thought:UnfalsifiableClaim a owl:Class ;
    rdfs:subClassOf thought:StructuralDefect ;
    rdfs:label "Unfalsifiable Claim" ;
    rdfs:comment "A claim structured so that no possible evidence could count against it." .

# ── Epistemic Vices ───────────────────────────────────────────────────────
# Dispositional failures in how a thinker relates to inquiry.

thought:EpistemicVice a owl:Class ;
    rdfs:subClassOf thought:Defect ;
    rdfs:label "Epistemic Vice" ;
    rdfs:comment "A dispositional failure in how a thinker relates to evidence, argument, and inquiry." .

thought:Dogmatism a owl:Class ;
    rdfs:subClassOf thought:EpistemicVice ;
    rdfs:label "Dogmatism" ;
    rdfs:comment "Holding a position with more certainty than evidence warrants, resistant to revision." .

thought:IntellectualCowardice a owl:Class ;
    rdfs:subClassOf thought:EpistemicVice ;
    rdfs:label "Intellectual Cowardice" ;
    rdfs:comment "Avoiding positions or arguments because they are socially costly, not because they are unwarranted." .

thought:MotivatedReasoning a owl:Class ;
    rdfs:subClassOf thought:EpistemicVice ;
    rdfs:label "Motivated Reasoning" ;
    rdfs:comment "Reasoning toward a desired conclusion rather than following evidence wherever it leads." .

thought:IntellectualDishonesty a owl:Class ;
    rdfs:subClassOf thought:EpistemicVice ;
    rdfs:label "Intellectual Dishonesty" ;
    rdfs:comment "Knowingly misrepresenting evidence, arguments, or one's own beliefs." .

thought:Incuriosity a owl:Class ;
    rdfs:subClassOf thought:EpistemicVice ;
    rdfs:label "Incuriosity" ;
    rdfs:comment "Failure to investigate relevant questions or follow up on anomalies." .

# ── Defect Relations ──────────────────────────────────────────────────────

thought:affects a owl:ObjectProperty ;
    rdfs:label "affects" ;
    rdfs:comment "The thought component that this defect undermines or distorts." ;
    rdfs:domain thought:Defect ;
    rdfs:range thought:Component .

thought:severity a owl:DatatypeProperty ;
    rdfs:label "severity" ;
    rdfs:comment "How seriously the defect undermines the affected component: minor, moderate, severe, fatal." ;
    rdfs:domain thought:Defect ;
    rdfs:range xsd:string .

thought:remediation a owl:DatatypeProperty ;
    rdfs:label "remediation" ;
    rdfs:comment "Suggested action to address the defect." ;
    rdfs:domain thought:Defect ;
    rdfs:range xsd:string .

thought:defectLabel a owl:DatatypeProperty ;
    rdfs:label "defect label" ;
    rdfs:comment "Human-readable name for this specific defect instance (e.g., the specific fallacy name)." ;
    rdfs:domain thought:Defect ;
    rdfs:range xsd:string .

thought:defectIn a owl:ObjectProperty ;
    rdfs:label "defect in" ;
    rdfs:comment "The note where the defect was identified." ;
    rdfs:domain thought:Defect ;
    rdfs:range minerva:Note .
